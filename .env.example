# Honcho — Unraid environment variables
# Copy to .env: cp .env.example .env

# ── API access ───────────────────────────────────────────
API_HOST=0.0.0.0           # 127.0.0.1 to restrict to local reverse proxy
API_PORT=8000              # Port on your Unraid LAN

# ── Database (PostgreSQL + pgvector) ────────────────────
POSTGRES_USER=honcho
POSTGRES_PASSWORD=CHANGE_THIS
POSTGRES_DB=honcho

# ── Permissions (Unraid defaults) ───────────────────────
PUID=99
PGID=100
UMASK=022

# ── Appdata path ────────────────────────────────────────
APPDATA_ROOT=/mnt/user/appdata/Compose/honcho

# ── LLM Providers ───────────────────────────────────────
# Two slots: "vllm" (light tasks) + "custom" (heavy tasks)
# Embeddings have their own separate path below.

# Primary: Local Ollama (light tasks — deriver, summary, low-level dialectic)
# Your Unraid tower runs Ollama. Model: qwen3.5:4b
LLM_VLLM_API_KEY=none
LLM_VLLM_BASE_URL=http://192.168.1.79:11434/v1

# Heavy: Ollama Cloud subscription (medium+ dialectic, dream)
# Get your key at: https://ollama.com/settings
LLM_OPENAI_COMPATIBLE_API_KEY=sk-your-ollama-cloud-key

# ── Embeddings: Local Ollama (embeddinggemma) ────────────
LLM_EMBEDDING_API_KEY=none
LLM_EMBEDDING_BASE_URL=http://192.168.1.79:11434/v1
LLM_EMBEDDING_MODEL=embeddinggemma

# embeddinggemma uses 768 dimensions (NOT OpenAI's 1536)
EMBEDDING_VECTOR_DIMENSIONS=768

# ── Client init (needed, uses local) ────────────────────
LLM_OPENAI_API_KEY=none
