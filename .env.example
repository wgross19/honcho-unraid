# Honcho — Unraid environment variables
# Copy to .env: cp .env.example .env

# ── API access ───────────────────────────────────────────
API_HOST=0.0.0.0           # 127.0.0.1 to restrict to local reverse proxy
API_PORT=8000              # Port on your Unraid LAN

# ── Database (PostgreSQL + pgvector) ────────────────────
POSTGRES_USER=honcho
POSTGRES_PASSWORD=CHANGE_THIS
POSTGRES_DB=honcho

# ── Permissions (Unraid defaults) ───────────────────────
PUID=99
PGID=100
UMASK=022

# ── Appdata path ────────────────────────────────────────
APPDATA_ROOT=/mnt/user/appdata/Compose/honcho

# ── LLM Provider (REQUIRED — Honcho won't start without this) ──
# Strategy: elkimek/honcho-self-hosted uses two slots:
#   "vllm"  = primary (any OpenAI-compatible endpoint)
#   "custom" = optional backup (kicks in on final retry)
#
# Cloud API (recommended):
LLM_VLLM_API_KEY=sk-your-openrouter-key
LLM_VLLM_BASE_URL=https://openrouter.ai/api/v1

# Embeddings (falls back to LLM_OPENAI_COMPATIBLE_* if empty)
LLM_EMBEDDING_API_KEY=sk-your-openrouter-key
LLM_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
LLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional backup provider (leave empty to disable)
# LLM_OPENAI_COMPATIBLE_API_KEY=sk-your-backup-key

# Needed for Honcho client init (can be same as primary)
LLM_OPENAI_API_KEY=sk-your-openrouter-key

# ── Alternative: Local / LAN inference (Ollama, vLLM) ───
# Uncomment and fill in instead of the Cloud API section above:
#
# LLM_VLLM_API_KEY=none
# LLM_VLLM_BASE_URL=http://192.168.1.XX:11434/v1
# LLM_OPENAI_API_KEY=none
# LLM_EMBEDDING_API_KEY=sk-your-openrouter-key   # still need cloud for embeddings
# LLM_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# LLM_EMBEDDING_MODEL=openai/text-embedding-3-small
# LLM_OPENAI_COMPATIBLE_API_KEY=none
#
# Then edit config.toml: replace model names (z-ai/glm-4.7-flash, x-ai/grok-4.1-fast,
# z-ai/glm-5) with your local model names. Remove BACKUP_PROVIDER / BACKUP_MODEL lines.
