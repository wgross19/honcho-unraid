# Honcho — Unraid environment variables
# Copy to .env: cp .env.example .env

# ── API access ───────────────────────────────────────────
API_HOST=0.0.0.0           # 127.0.0.1 to restrict to local reverse proxy
API_PORT=8000              # Port on your Unraid LAN

# ── Database (PostgreSQL + pgvector) ────────────────────
POSTGRES_USER=honcho
POSTGRES_PASSWORD=CHANGE_THIS
POSTGRES_DB=honcho

# ── Permissions (Unraid defaults) ───────────────────────
PUID=99
PGID=100
UMASK=022

# ── Appdata path ────────────────────────────────────────
APPDATA_ROOT=/mnt/user/appdata/Compose/honcho

# ── LLM Providers ───────────────────────────────────────
# Runtime model routing lives in config/config.toml.
# These values are only credentials/placeholders referenced by api_key_env.

# Local Ollama on your Unraid tower.
# Used for deriver, summary, minimal dialectic, fallbacks, and embeddings.
LLM_VLLM_API_KEY=none
LLM_EMBEDDING_API_KEY=none

# Ollama Cloud subscription.
# Get your key at: https://ollama.com/settings
# Used for DeepSeek V4 Flash/Pro dialectic levels and heavy fallbacks.
LLM_OPENAI_COMPATIBLE_API_KEY=sk-you...-key

# Honcho's generic OpenAI key. Kept as a harmless placeholder because some
# clients/init paths expect it to exist; config.toml uses explicit api_key_env.
LLM_OPENAI_API_KEY=none
